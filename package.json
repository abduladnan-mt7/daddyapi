{
  "name": "daddyapi-monorepo",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Point daddyapi at a bot-friendly website and get a documented API.",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
